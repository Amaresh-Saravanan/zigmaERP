# Read by `docker compose` (via docker-compose.yml) at the repo root.
# Copy to `.env` and fill in real values — never commit the real file.
DEBUG=False
SECRET_KEY=<a-long-random-production-secret>
MONGODB_URI=mongodb+srv://<user>:<password>@<your-cluster>.mongodb.net/zigma_erp_prod
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
