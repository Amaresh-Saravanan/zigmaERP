<script>
    document.addEventListener('DOMContentLoaded', function () {
        const trayStatusList = document.getElementById('tray-status-list');
        const trayStatus = <?php echo $js_tray_status; ?>;
        const unutilizedTrays = <?php echo $js_unutilized_trays; ?>;

        const icons = [
        `<svg height="32" viewBox="0 0 32 32" width="32" xmlns="http://www.w3.org/2000/svg">
            <g fill="none">
                <circle cx="16" cy="16" fill="#49c1bf" r="16"/>
                <g fill="#fff">
                    <path d="M9 7.281l11.114 5.383 2.845-1.282L11.891 6z" fill-opacity=".304"/>
                    <path d="M20.114 12.651l2.845-1.281v2.865l-2.845 1.281zm0 13.284v-8.937l2.845-1.295v8.951z" fill-opacity=".646"/>
                    <path d="M9 7.284v2.897l7.693 3.737L9 17.728v2.856l11.114 5.373v-2.874l-7.548-3.671 7.548-3.881v-2.865z"/>
                </g>
            </g>
            <a href="#" data="day1" onclick="openwindow(this.getAttribute('data'))" style="cursor: pointer; display: block; width: 100%; height: 100%; position: absolute; top: 0; left: 0;"></a>
        </svg>`,  // Day 1 - Egg
        `<svg height="32" viewBox="0 0 32 32" width="32" xmlns="http://www.w3.org/2000/svg">
            <g fill="none">
                <circle cx="16" cy="16" fill="#e76f51" r="16"/>
                <g fill="#fff">
                    <path d="M9 7.281l11.114 5.383 2.845-1.282L11.891 6z" fill-opacity=".304"/>
                    <path d="M20.114 12.651l2.845-1.281v2.865l-2.845 1.281zm0 13.284v-8.937l2.845-1.295v8.951z" fill-opacity=".646"/>
                    <path d="M9 7.284v2.897l7.693 3.737L9 17.728v2.856l11.114 5.373v-2.874l-7.548-3.671 7.548-3.881v-2.865z"/>
                </g>
            </g>
            <a href="#" data="day2" onclick="openwindow(this.getAttribute('data'))" style="cursor: pointer; display: block; width: 100%; height: 100%; position: absolute; top: 0; left: 0;"></a>
        </svg>`,  // Day 2 - Egg Cracking
        `<svg height="32" viewBox="0 0 32 32" width="32" xmlns="http://www.w3.org/2000/svg">
            <g fill="none">
                <circle cx="16" cy="16" fill="#f4a261" r="16"/>
                <g fill="#fff">
                    <path d="M9 7.281l11.114 5.383 2.845-1.282L11.891 6z" fill-opacity=".304"/>
                    <path d="M20.114 12.651l2.845-1.281v2.865l-2.845 1.281zm0 13.284v-8.937l2.845-1.295v8.951z" fill-opacity=".646"/>
                    <path d="M9 7.284v2.897l7.693 3.737L9 17.728v2.856l11.114 5.373v-2.874l-7.548-3.671 7.548-3.881v-2.865z"/>
                </g>
            </g>
            <a href="#" data="day3" onclick="openwindow(this.getAttribute('data'))" style="cursor: pointer; display: block; width: 100%; height: 100%; position: absolute; top: 0; left: 0;"></a>
        </svg>`,  // Day 3 - Small Larvae
        `<svg height="32" viewBox="0 0 32 32" width="32" xmlns="http://www.w3.org/2000/svg">
            <g fill="none">
                <circle cx="16" cy="16" fill="#e9c46a" r="16"/>
                <g fill="#fff">
                    <path d="M9 7.281l11.114 5.383 2.845-1.282L11.891 6z" fill-opacity=".304"/>
                    <path d="M20.114 12.651l2.845-1.281v2.865l-2.845 1.281zm0 13.284v-8.937l2.845-1.295v8.951z" fill-opacity=".646"/>
                    <path d="M9 7.284v2.897l7.693 3.737L9 17.728v2.856l11.114 5.373v-2.874l-7.548-3.671 7.548-3.881v-2.865z"/>
                </g>
            </g>
            <a href="#" data="day4" onclick="openwindow(this.getAttribute('data'))" style="cursor: pointer; display: block; width: 100%; height: 100%; position: absolute; top: 0; left: 0;"></a>
        </svg>`,  // Day 4 - Growing Larvae
        `<svg height="32" viewBox="0 0 32 32" width="32" xmlns="http://www.w3.org/2000/svg">
            <g fill="none">
                <circle cx="16" cy="16" fill="#2a9d8f" r="16"/>
                <g fill="#fff">
                    <path d="M9 7.281l11.114 5.383 2.845-1.282L11.891 6z" fill-opacity=".304"/>
                    <path d="M20.114 12.651l2.845-1.281v2.865l-2.845 1.281zm0 13.284v-8.937l2.845-1.295v8.951z" fill-opacity=".646"/>
                    <path d="M9 7.284v2.897l7.693 3.737L9 17.728v2.856l11.114 5.373v-2.874l-7.548-3.671 7.548-3.881v-2.865z"/>
                </g>
            </g>
            <a href="#" data="day5" onclick="openwindow(this.getAttribute('data'))" style="cursor: pointer; display: block; width: 100%; height: 100%; position: absolute; top: 0; left: 0;"></a>
        </svg>`   // Day 5 - Large Larvae
    ];

    trayStatus.forEach((status, index) => {
    const listItem = document.createElement('li');
    listItem.classList.add('list-group-item', 'd-flex', 'align-items-center');

    const iconDiv = document.createElement('div');
    iconDiv.classList.add('flex-shrink-0');

    // Check if the tray age is above 5 days
    if (status.tray_age === 'Above 5 Days') {
        iconDiv.innerHTML = `<svg height="32" viewBox="0 0 32 32" width="32" xmlns="http://www.w3.org/2000/svg"><g fill="none"><circle cx="16" cy="16" fill="#e63946" r="16"/><g fill="#fff"><path d="M9 7.281l11.114 5.383 2.845-1.282L11.891 6z" fill-opacity=".304"/><path d="M20.114 12.651l2.845-1.281v2.865l-2.845 1.281zm0 13.284v-8.937l2.845-1.295v8.951z" fill-opacity=".646"/><path d="M9 7.284v2.897l7.693 3.737L9 17.728v2.856l11.114 5.373v-2.874l-7.548-3.671 7.548-3.881v-2.865z"/></g></g></svg>`;
        // Adding click event directly on the div
        iconDiv.onclick = () => openwindow('above5days');
    } else {
        // Set the icon for days 1 to 5
        iconDiv.innerHTML = icons[status.tray_age - 1];
        // Set the click event to open a new window based on day
        iconDiv.onclick = () => openwindow(`day${status.tray_age}`);
    }

    const trayAgeDiv = document.createElement('div');
    trayAgeDiv.classList.add('flex-grow-1', 'ms-3');
    trayAgeDiv.innerHTML = `<h6 class="fs-14 mb-1">${status.tray_age === 'Above 5 Days' ? 'Above 5 Days' : 'Day ' + status.tray_age}</h6>`;

    const trayUtilizedDiv = document.createElement('div');
    trayUtilizedDiv.classList.add('flex-shrink-0', 'text-end');
    trayUtilizedDiv.innerHTML = `<h6 class="fs-14 mb-1">${status.tray_utilized}</h6>`;

    listItem.appendChild(iconDiv);
    listItem.appendChild(trayAgeDiv);
    listItem.appendChild(trayUtilizedDiv);

    trayStatusList.appendChild(listItem);
});

        // Add the Unutilized Trays row
        const unutilizedTraysItem = document.createElement('li');
        unutilizedTraysItem.classList.add('list-group-item', 'd-flex', 'align-items-center');

        const unutilizedTraysIconDiv = document.createElement('div');
        unutilizedTraysIconDiv.classList.add('flex-shrink-0');

        // Create the SVG icon
        unutilizedTraysIconDiv.innerHTML = `<svg height="32" viewBox="0 0 32 32" width="32" xmlns="http://www.w3.org/2000/svg"><g fill="none"><circle cx="16" cy="16" fill="#228B22" r="16"/><g fill="#fff"><path d="M9 7.281l11.114 5.383 2.845-1.282L11.891 6z" fill-opacity=".304"/><path d="M20.114 12.651l2.845-1.281v2.865l-2.845 1.281zm0 13.284v-8.937l2.845-1.295v8.951z" fill-opacity=".646"/><path d="M9 7.284v2.897l7.693 3.737L9 17.728v2.856l11.114 5.373v-2.874l-7.548-3.671 7.548-3.881v-2.865z"/></g></g></svg>`;

        // Add click event to the icon to open a new window
        unutilizedTraysIconDiv.onclick = function() {
            openwindow('unutilized-trays'); // Call openwindow function with the identifier
        };

        const unutilizedTraysAgeDiv = document.createElement('div');
        unutilizedTraysAgeDiv.classList.add('flex-grow-1', 'ms-3');
        unutilizedTraysAgeDiv.innerHTML = `<h6 class="fs-14 mb-1">
        Unutilized Trays
        </h6>`;

        // Create the utilized trays div
        const unutilizedTraysUtilizedDiv = document.createElement('div');
        unutilizedTraysUtilizedDiv.classList.add('flex-shrink-0', 'text-end');
        unutilizedTraysUtilizedDiv.innerHTML = `<h6 class="fs-14 mb-1">${unutilizedTrays}</h6>`;

        // Append elements to the list item
        unutilizedTraysItem.appendChild(unutilizedTraysIconDiv);
        unutilizedTraysItem.appendChild(unutilizedTraysAgeDiv);
        unutilizedTraysItem.appendChild(unutilizedTraysUtilizedDiv);

        // Append the item to the tray status list
        trayStatusList.appendChild(unutilizedTraysItem);

    });
// -------------------graph star--------------
    
document.addEventListener('DOMContentLoaded', function () {
    // Fetch the necessary data
    let batchAges = <?php echo $js_batch_ages; ?>;
    let batchIds = <?php echo $js_batch_ids; ?>;
    let feedQtys = <?php echo $js_feed_qty; ?>;
    let larvaeQtys = <?php echo $js_larvae_qty_in; ?>;
    let daysSinceLarvaeEntry = <?php echo $js_days_since_larvae_entry; ?>;
    let categories = <?php echo $js_categories; ?>;

    // Create an array of objects to handle sorting
    let chartData = batchAges.map((age, index) => ({
        age: age,
        id: batchIds[index],
        feedQty: feedQtys[index],
        larvaeQty: larvaeQtys[index],
        daysSinceEntry: daysSinceLarvaeEntry[index],
        category: categories[index]
    }));

    // Sort the array based on the max batch age (descending order)
    chartData.sort((a, b) => b.age - a.age);

    // Extract sorted data back to individual arrays
    let sortedBatchAges = chartData.map(item => item.age);
    let sortedBatchIds = chartData.map(item => item.id);
    let sortedFeedQtys = chartData.map(item => item.feedQty);
    let sortedLarvaeQtys = chartData.map(item => item.larvaeQty);
    let sortedDaysSinceEntry = chartData.map(item => item.daysSinceEntry);
    let sortedCategories = chartData.map(item => item.category);

    // Configure the chart
    var options = {
        series: [{
            name: 'Batch Age',
            data: sortedBatchAges
        }],
        chart: {
            type: 'bar',
            height: 450,
            background: '#f4f4f4',
            foreColor: '#333',
            events: {
                dataPointSelection: function(event, chartContext, config) {
                    var formBatchId = sortedBatchIds[config.dataPointIndex];
                    window.open(`../erp/folders/pit_status_report/print.php?pit_id=${formBatchId}`);
                }
            }
        },
        plotOptions: {
            bar: {
                borderRadius: 4,
                horizontal: true,
            }
        },
        // 1234567
        dataLabels: {
            enabled: true,
            formatter: function (val, { seriesIndex, dataPointIndex }) {
                var feedQty = sortedFeedQtys[dataPointIndex];                
                if((val == 0) || feedQty=='0'){
                    return  " -";
            }else{
                
                return val + " Days - " + feedQty + " Tons";
                }
               
            },
            
            style: {
                colors: ['#304758']
            }
        },
       
        xaxis: {
            categories: sortedCategories,
            title: {
                text: 'Batch Age (days)',
                style: {
                    color: '#333',
                    fontSize: '14px'
                }
            }
        },
        yaxis: {
            title: {
                text: 'Pit Name',
                style: {
                    color: '#333',
                    fontSize: '14px'
                }
            }
        },
        tooltip: {
            custom: function({series, seriesIndex, dataPointIndex, w}) {
                var pitName = w.globals.labels[dataPointIndex];
                var batchAge = series[seriesIndex][dataPointIndex] + ' days';
                var feedQty = sortedFeedQtys[dataPointIndex];
                var formBatchId = sortedBatchIds[dataPointIndex];
                var larvaeQty = sortedLarvaeQtys[dataPointIndex];
                var daysSinceEntry = sortedDaysSinceEntry[dataPointIndex];

                larvaeQty = larvaeQty === 0 ? '-' : larvaeQty + ' Kg';
                daysSinceEntry = daysSinceEntry === '-' ? '-' : daysSinceEntry + ' days';

                return `<div class="tooltip-box">
                            <span><strong>Pit Name: </strong> ${pitName}</span><br>
                            <span><strong>Batch Age: </strong> ${batchAge}</span><br>
                            <span><strong>Feed Quantity: </strong> ${feedQty}</span><br>
                            <span><strong>Batch ID: </strong> ${formBatchId}</span><br>
                            <span><strong>Larvae Feed Quantity: </strong> ${larvaeQty}</span><br>
                            <span><strong>Days Since Larvae Entry: </strong> ${daysSinceEntry}</span>
                        </div>`;
            },
            theme: 'dark'
        },
        fill: {
            colors: ['#ADD8E6'],
            opacity: 0.9,
            gradient: {
                shade: 'light',
                type: 'horizontal',
                shadeIntensity: 0.5,
                inverseColors: true,
                opacityFrom: 0.85,
                opacityTo: 0.85,
                stops: [0, 100]
            }
        },
        grid: {
            borderColor: '#f1f1f1',
            padding: {
                right: 20,
                left: 20
            }
        }
    };

    var chart = new ApexCharts(document.querySelector("#chartbsar"), options);
    chart.render();
});


