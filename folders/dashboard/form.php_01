<?php

ini_set('display_errors', 1);
ini_set('display_startup_errors', 1);
error_reporting(E_ALL);

$host = "192.168.1.200";
$username = "my_root";
$password = "my@123456";
$databasename = "zigfly_erp";
$selected_month ="";
$current_month = date('Y-m');
$month ='';

try {
    // Initialize PDO instance
    $pdo = new PDO("mysql:host=$host;dbname=$databasename", $username, $password);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

    // Initialize variables
    $table_sub1 = "pit_status";
    $table_sub2 = "egg_process";
    $table_sub3 = "pit_status";
    $table_tray_creation = "tray_creation";
    // $_POST['month']='';
    if(isset($_POST['month']) && $_POST['month'] != ''){
        $month = $_POST['month'];
    } else {
        $month = $current_month;
    }
    

    $columns1 = [
    "sum(feed_qty)  as organic_waste",
    "sum(larvae_qty)  as larvae_qty",
    "sum(qty_rejets) as qty_rejets", 
    "sum(qty_manure_1 + qty_manure_2) as total_qty_manure" ,
    "sum(larvae_qty_in)  as egg_hatching"
    ];
    

    $columns2 = [
        " sum(tot_qty) as total_egg_qty",  //purchase in 
    ];
    $columns2_overall = [
        " sum(tot_qty) as total_egg_qty",  //purchase in 
    ];

    $columns3 = [
        "pc.pit_name",


        "(SELECT SUM(feed_qty) from pit_status where is_delete = 0  AND form_batch_id = recent_batch.recent_batch_id) as total_feed_qty",
        // "MIN(ps.entry_date) AS first_entry_date",
        "(SELECT min(entry_date) from pit_status where  org_status= 1 and is_delete = 0  AND form_batch_id = recent_batch.recent_batch_id) as first_entry_date",
        "(SELECT max(entry_date) from pit_status where  org_status= 1 and  is_delete = 0  AND form_batch_id = recent_batch.recent_batch_id) as last_entry_date",
        "(SELECT max(harvest_comp) from pit_status where is_delete = 0 AND form_batch_id = recent_batch.recent_batch_id) as harvest_comp",

       "( SELECT 
            DATEDIFF(CURDATE(), MIN(entry_date)) 
        FROM 
            pit_status 
        WHERE 
            is_delete = 0 
            AND form_batch_id = recent_batch.recent_batch_id and feed_count=1 )as batch_age",

        "recent_batch.recent_batch_id",
        // "larvae_data.larvae_qty_in",
        "(SELECT SUM(larvae_qty_in) from pit_status where is_delete = 0 AND form_batch_id = recent_batch.recent_batch_id) as larvae_qty_in",
        
        "IF(larvae_data.org_status = 2, DATEDIFF(CURDATE(), larvae_data.larvae_entry_date) + 1, 0) AS days_since_larvae_entry"
    ];

    $join3 = "
        JOIN pit_creation pc ON pc.unique_id = ps.pit_id
        LEFT JOIN (
            SELECT pit_id, MAX(form_batch_id) AS recent_batch_id
            FROM pit_status where is_delete=0
            GROUP BY pit_id
        ) recent_batch ON recent_batch.pit_id = ps.pit_id 
        LEFT JOIN (
            SELECT pit_id, form_batch_id,larvae_qty_in, entry_date AS larvae_entry_date, org_status
            FROM pit_status
            WHERE org_status = 2
        ) larvae_data ON larvae_data.pit_id = ps.pit_id AND larvae_data.form_batch_id = recent_batch.recent_batch_id
    ";
    $where3 = " ps.is_delete = 0 and DATE_FORMAT(ps.entry_date,'%Y-%m')='$month' GROUP BY ps.pit_id";
    $where3_overall = " ps.is_delete = 0 GROUP BY ps.pit_id";
    
    // Construct SQL queries
    $query1 = "SELECT " . implode(", ", $columns1) . " FROM $table_sub1 WHERE is_delete = 0 and  DATE_FORMAT(entry_date,'%Y-%m')='$month'";
    $query2 = "SELECT " . implode(", ", $columns2) . " FROM $table_sub2 WHERE is_delete = 0 and DATE_FORMAT(entry_date,'%Y-%m')='$month'";
   
    $query1_overall = "SELECT " . implode(", ", $columns1) . " FROM $table_sub1 WHERE is_delete = 0 ";
    $query2_overall = "SELECT " . implode(", ", $columns2) . " FROM $table_sub2 WHERE is_delete = 0 ";
    $query3_overall = "SELECT " . implode(", ", $columns3) . " FROM $table_sub3 ps $join3 WHERE  $where3_overall";

    $query3 = "SELECT " . implode(", ", $columns3) . " FROM $table_sub3 ps $join3 WHERE  $where3";
    $query4 = "SELECT entry_date, SUM(tray_utilized) tray_utilized FROM $table_sub2 WHERE batch_status=0 and is_delete = 0  GROUP BY entry_date";
    // $query4 = "SELECT entry_date,SUM(tray_utilized) tray_utilized FROM $table_sub2 WHERE batch_status=0 and is_delete = 0 and  DATE_FORMAT(entry_date,'%Y-%m')='$month' GROUP BY entry_date";
    
    $query5 = "SELECT COUNT(unique_id) AS unutilized_trays FROM $table_tray_creation WHERE tray_status = 0 AND is_active = 1 AND is_delete = 0 AND  bin_name not LIKE'%TEST%'";

    // print_r($query4);
    // Execute queries
    $stmt1 = $pdo->query($query1);
    $result_values1 = $stmt1->fetch(PDO::FETCH_ASSOC);

    $stmt2 = $pdo->query($query2);
    $result_values2 = $stmt2->fetch(PDO::FETCH_ASSOC);

    $stmt3 = $pdo->query($query3);
    $result_values3 = $stmt3->fetchAll(PDO::FETCH_ASSOC);
    // ---------------------------------------------------------
    $stmt1_overall = $pdo->query($query1_overall);
    $result_values1_overall = $stmt1_overall->fetch(PDO::FETCH_ASSOC);

    $stmt2_overall = $pdo->query($query2_overall);
    $result_values2_overall = $stmt2_overall->fetch(PDO::FETCH_ASSOC);

    $stmt3_overall = $pdo->query($query3_overall);
    $result_values3_overall = $stmt3_overall->fetchAll(PDO::FETCH_ASSOC);
    // ----------------------------------------

// print_r($stmt3);
    $stmt4 = $pdo->query($query4);
    $result_values4 = $stmt4->fetchAll(PDO::FETCH_ASSOC);

    $stmt5 = $pdo->query($query5);
    $result_values5 = $stmt5->fetch(PDO::FETCH_ASSOC);

    // Process results
    if ($result_values1) {
        $organic_waste = $result_values1["organic_waste"] ?? 0;
        $larvae_qty = $result_values1["larvae_qty"] / 1000 ?? 0; // Dividing by 1000
        $qty_rejects = $result_values1["qty_rejets"] / 1000 ?? 0; // Dividing by 1000
        $total_qty_manure = $result_values1["total_qty_manure"] / 1000 ?? 0; 
        $egg_hatching = $result_values1["egg_hatching"]  ?? 0;// Dividing by 1000
    } else {
        $organic_waste = $larvae_qty = $qty_rejects = $total_qty_manure = 0;
    }

    if ($result_values2) {
        $total_egg_qty = $result_values2["total_egg_qty"] ?? 0;
    } else {
        $total_egg_qty = 0;
    }

    // Initialize arrays
$categories = $data = $feed_qty = $entry_dates = $batch_ids = $batch_ages = $larvae_qty_in = $days_since_larvae_entry = [];

foreach ($result_values3 as $row) {
    $categories[] = $row['pit_name'];
    $data[] = (int)$row['batch_age'];
    $feed_qty[] = (int)$row['total_feed_qty'];
    $entry_dates[] = $row['first_entry_date'];
    $batch_ids[] = $row['recent_batch_id'];
    // $batch_age=$row['batch_age'] + 1;

    if (!empty($row['first_entry_date'])){
    $date1 = new DateTime($row['first_entry_date']);
    }

    if (!empty($row['last_entry_date']) && ($row['harvest_comp'] == '2')) {
        $date2 = new DateTime($row['last_entry_date']);
    } else {
        $date2 = new DateTime(); 
    }
   
// ----------------------------------------
    $interval = $date1->diff($date2);        //dashboard issue 
    $daysDifference = $interval->days;
//    ------------------------------
  


    
    if (!empty($row['last_entry_date'] == $row['first_entry_date']) && $row['days_since_larvae_entry'] !=0) {
        $row['batch_age']= $row['batch_age'] +1;
    }
    elseif(($row['harvest_comp'] != '2') && ($row['days_since_larvae_entry'] !=0 )){  
        $row['batch_age']= $daysDifference+ 1;
    }
    else{
        $row['batch_age']='0';
    }

    $batch_ages[] = $row['batch_age'];
    $larvae_qty_in[] = (int)$row['larvae_qty_in'];
    $days_since_larvae_entry[] = (int)$row['days_since_larvae_entry'];
}

// Combine the data into an associative array for sorting
$combined_data = [];
for ($i = 0; $i < count($categories); $i++) {
    $combined_data[] = [
        'category' => $categories[$i],
        'data' => $data[$i],
        'feed_qty' => $feed_qty[$i],
        'entry_date' => $entry_dates[$i],
        'batch_id' => $batch_ids[$i],
        'batch_age' => $batch_ages[$i],
        'larvae_qty_in' => $larvae_qty_in[$i],
        'days_since_larvae_entry' => $days_since_larvae_entry[$i],
    ];
}

// Sort the combined data array by 'category' (pit_name) in descending order
usort($combined_data, function ($a, $b) {
    return strcmp($b['category'], $a['category']);
});

// Unpack the sorted data back into the individual arrays
$categories = array_column($combined_data, 'category');
$data = array_column($combined_data, 'data');
$feed_qty = array_column($combined_data, 'feed_qty');
$entry_dates = array_column($combined_data, 'entry_date');
$batch_ids = array_column($combined_data, 'batch_id');
$batch_ages = array_column($combined_data, 'batch_age');
$larvae_qty_in = array_column($combined_data, 'larvae_qty_in');
$days_since_larvae_entry = array_column($combined_data, 'days_since_larvae_entry');

// Convert the sorted arrays into JavaScript-friendly JSON format
$js_categories = json_encode($categories);
$js_data = json_encode($data);
$js_feed_qty = json_encode($feed_qty);
$js_entry_dates = json_encode($entry_dates);
$js_batch_ids = json_encode($batch_ids);
$js_batch_ages = json_encode($batch_ages);
$js_larvae_qty_in = json_encode($larvae_qty_in);
$js_days_since_larvae_entry = json_encode($days_since_larvae_entry);
// -------------------------------------------------------------------
if ($result_values1_overall) {
    $organic_waste_overall = $result_values1_overall["organic_waste"] ?? 0;
    $larvae_qty_overall = $result_values1_overall["larvae_qty"] / 1000 ?? 0; // Dividing by 1000
    $qty_rejects_overall = $result_values1_overall["qty_rejets"] / 1000 ?? 0; // Dividing by 1000
    $total_qty_manure_overall = $result_values1_overall["total_qty_manure"] / 1000 ?? 0; 
    $egg_hatching_overall = $result_values1_overall["egg_hatching"]  ?? 0;// Dividing by 1000
} else {
    $organic_waste_overall = $larvae_qty_overall = $qty_rejects_overall = $total_qty_manure_overall = 0;
}

if ($result_values2_overall) {
    $total_egg_qty_overall = $result_values2_overall["total_egg_qty"] ?? 0;
} else {
    $total_egg_qty_overall = 0;
}

    if ($result_values4) {
        // Initialize arrays for tray status
        $tray_status = [];
        $above_five_days = 0; // Initialize variable for trays above 5 days
        for ($i = 0; $i < 5; $i++) {
            $tray_status[$i] = ['tray_age' => $i + 1, 'tray_utilized' => 0];
        }
        foreach ($result_values4 as $row) {
            $tray_age = (new DateTime())->diff(new DateTime($row['entry_date']))->days + 1;
            if ($tray_age <= 5) {
                $tray_status[$tray_age - 1]['tray_utilized'] = $row['tray_utilized'];
            } else {
                $above_five_days += $row['tray_utilized']; // Sum tray utilization for trays above 5 days
            }
        }

        // Add trays above 5 days to tray_status array
        $tray_status[] = ['tray_age' => 'Above 5 Days', 'tray_utilized' => $above_five_days];

        // Convert the PHP array into JavaScript arrays
        $js_tray_status = json_encode($tray_status);
    } else {
        $js_tray_status = json_encode([]);
    }

    // Process unutilized trays
    if ($result_values5) {
        $unutilized_trays = $result_values5["unutilized_trays"] ?? 0;
        $js_unutilized_trays = json_encode($unutilized_trays);
    } else {
        $unutilized_trays = 0;
        $js_unutilized_trays = json_encode($unutilized_trays);
    }

} catch (PDOException $e) {
    echo "Error: " . $e->getMessage();
}
?>

