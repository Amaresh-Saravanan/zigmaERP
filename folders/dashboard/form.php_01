<script>
function new_external_window_print(element) {
    var month = element.getAttribute('value'); 
    var type = element.closest('.type').getAttribute('data-value');

    // alert(type); 
    window.open('./folders/dashboard/organic.php?month=' + month + '&type=' + type, '_blank', 'width=800,height=600');
}

function openwindow(data) {
    window.open('./folders/dashboard/tray_status.php?data=' + data, '_blank', 'width=800,height=600');
}
</script>